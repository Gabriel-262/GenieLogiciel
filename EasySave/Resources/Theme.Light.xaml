<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Space Marine - bone / pale ceramite variant -->
    <SolidColorBrush x:Key="BackgroundBrush"         Color="#FFEDE5D0"/>
    <SolidColorBrush x:Key="SurfaceBrush"            Color="#FFF7F0DA"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"         Color="#FFE0D6B7"/>
    <SolidColorBrush x:Key="BorderBrush"             Color="#FF3A578A"/>
    <SolidColorBrush x:Key="ForegroundBrush"         Color="#FF0E1B33"/>
    <SolidColorBrush x:Key="MutedForegroundBrush"    Color="#FF4A5A75"/>
    <SolidColorBrush x:Key="AccentBrush"             Color="#FF1F3A66"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"   Color="#FFF7F0DA"/>
    <SolidColorBrush x:Key="AccentSoftBrush"         Color="#FFCBB983"/>
    <SolidColorBrush x:Key="DangerBrush"             Color="#FF8B1A14"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"   Color="#FFF7F0DA"/>
    <SolidColorBrush x:Key="SuccessBrush"            Color="#FF3D6B2D"/>

</ResourceDictionary>
