<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundBrush"         Color="#FFF7F8FA"/>
    <SolidColorBrush x:Key="SurfaceBrush"            Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"         Color="#FFF1F3F5"/>
    <SolidColorBrush x:Key="BorderBrush"             Color="#FFE3E6EB"/>
    <SolidColorBrush x:Key="ForegroundBrush"         Color="#FF1F2937"/>
    <SolidColorBrush x:Key="MutedForegroundBrush"    Color="#FF6B7280"/>
    <SolidColorBrush x:Key="AccentBrush"             Color="#FF3B82F6"/>
    <SolidColorBrush x:Key="AccentHoverBrush"        Color="#FF2563EB"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="DangerBrush"             Color="#FFEF4444"/>
    <SolidColorBrush x:Key="DangerHoverBrush"        Color="#FFDC2626"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SuccessBrush"            Color="#FF10B981"/>
    <SolidColorBrush x:Key="WarningBrush"            Color="#FFF59E0B"/>

</ResourceDictionary>
