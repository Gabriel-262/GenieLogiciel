<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light palette overrides. Matches the default defined in Styles.xaml. -->
    <SolidColorBrush x:Key="BackgroundBrush"         Color="#FFF8F9FB"/>
    <SolidColorBrush x:Key="SurfaceBrush"            Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush"             Color="#FFD7DCE2"/>
    <SolidColorBrush x:Key="ForegroundBrush"         Color="#FF1F2937"/>
    <SolidColorBrush x:Key="MutedForegroundBrush"    Color="#FF6B7280"/>
    <SolidColorBrush x:Key="AccentBrush"             Color="#FF2563EB"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="DangerBrush"             Color="#FFDC2626"/>

</ResourceDictionary>
