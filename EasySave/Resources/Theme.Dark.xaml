<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark palette overrides. Merged at runtime by ThemeManager. -->
    <SolidColorBrush x:Key="BackgroundBrush"         Color="#FF0F172A"/>
    <SolidColorBrush x:Key="SurfaceBrush"            Color="#FF1E293B"/>
    <SolidColorBrush x:Key="BorderBrush"             Color="#FF334155"/>
    <SolidColorBrush x:Key="ForegroundBrush"         Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="MutedForegroundBrush"    Color="#FF94A3B8"/>
    <SolidColorBrush x:Key="AccentBrush"             Color="#FF3B82F6"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="DangerBrush"             Color="#FFEF4444"/>

</ResourceDictionary>
