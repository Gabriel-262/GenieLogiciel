<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundBrush"         Color="#FF15171C"/>
    <SolidColorBrush x:Key="SurfaceBrush"            Color="#FF1C1F26"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"         Color="#FF252932"/>
    <SolidColorBrush x:Key="BorderBrush"             Color="#FF323744"/>
    <SolidColorBrush x:Key="ForegroundBrush"         Color="#FFE6E8EB"/>
    <SolidColorBrush x:Key="MutedForegroundBrush"    Color="#FF9AA0AC"/>
    <SolidColorBrush x:Key="AccentBrush"             Color="#FF60A5FA"/>
    <SolidColorBrush x:Key="AccentHoverBrush"        Color="#FF93C5FD"/>
    <SolidColorBrush x:Key="AccentForegroundBrush"   Color="#FF0B1220"/>
    <SolidColorBrush x:Key="DangerBrush"             Color="#FFF87171"/>
    <SolidColorBrush x:Key="DangerHoverBrush"        Color="#FFEF4444"/>
    <SolidColorBrush x:Key="DangerForegroundBrush"   Color="#FF1B0E0E"/>
    <SolidColorBrush x:Key="SuccessBrush"            Color="#FF34D399"/>
    <SolidColorBrush x:Key="WarningBrush"            Color="#FFFBBF24"/>

</ResourceDictionary>
