<UserControl x:Class="EasySave.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Settings" Style="{StaticResource H1}"/>

            <!-- General -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <CheckBox Content="Auto-assign Job ID"
                              IsChecked="{Binding AutoAssignJobId}"
                              Click="AutoAssign_Click" Margin="0,0,0,12"/>

                    <TextBlock Text="Language" Style="{StaticResource Muted}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                        <Button Content="English"  Click="Lang_Click" Tag="en"/>
                        <Button Content="Français" Click="Lang_Click" Tag="fr"/>
                        <Button Content="中文"     Click="Lang_Click" Tag="zh"/>
                        <Button Content="עברית"   Click="Lang_Click" Tag="he"/>
                    </StackPanel>

                    <TextBlock Text="Theme" Style="{StaticResource Muted}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Light" Click="Theme_Click" Tag="light"/>
                        <Button Content="Dark"  Click="Theme_Click" Tag="dark"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Logging -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Logging" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource Muted}">
                        <Run Text="Format: "/>
                        <Run Text="{Binding LogFormat, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Content="Toggle JSON / XML" Margin="0,6,0,0"
                            Command="{Binding ToggleLogFormatCommand}"/>
                </StackPanel>
            </Border>

            <!-- Business software -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Business software monitor" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource Muted}"
                               Text="Backups are paused when this process is running."/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BusinessSoftwareBox" Grid.Column="0"
                                 Text="{Binding BusinessSoftwareName, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Save" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ChangeBusinessSoftwareNameCommand}"
                                CommandParameter="{Binding Text, ElementName=BusinessSoftwareBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Encryption -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Encryption (CryptoSoft)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource Muted}"
                               Text="File extensions encrypted after copy."/>

                    <TextBlock Text="Mode" Style="{StaticResource Muted}" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{Binding CryptoMode}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="Toggle (Rapide / Standard / Premium)"
                                Command="{Binding ToggleCryptoModeCommand}"/>
                    </StackPanel>

                    <TextBlock Text="Extensions" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding EncryptedExtensions}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="4"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        <Button Content="x" Margin="6,0,0,0" Padding="4,0"
                                                Command="{Binding DataContext.RemoveExtensionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewExtensionBox" Grid.Column="0"
                                 Tag="e.g. .txt"/>
                        <Button Grid.Column="1" Content="Add" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddExtensionCommand}"
                                CommandParameter="{Binding Text, ElementName=NewExtensionBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Paths -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Paths (apply on restart)" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Log"     VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="State"   VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding StatePath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Config"  VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Lang"    VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding LangPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save paths" Style="{StaticResource PrimaryButton}" Click="SavePaths_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
