<UserControl x:Class="EasySave.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="{DynamicResource UI_Settings_Title}" Style="{StaticResource H1}"/>

            <!-- General -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource UI_Settings_General}" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="{DynamicResource UI_Settings_Language}" Style="{StaticResource Muted}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                        <Button Content="English"  Click="Lang_Click" Tag="en"/>
                        <Button Content="Français" Click="Lang_Click" Tag="fr"/>
                        <Button Content="中文"     Click="Lang_Click" Tag="zh"/>
                        <Button Content="עברית"   Click="Lang_Click" Tag="he"/>
                        <Button Content="Kreyòl"  Click="Lang_Click" Tag="ht"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource UI_Settings_Theme}" Style="{StaticResource Muted}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="{DynamicResource UI_Theme_Light}" Click="Theme_Click" Tag="light"/>
                        <Button Content="{DynamicResource UI_Theme_Dark}"  Click="Theme_Click" Tag="dark"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Logging -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource UI_Settings_Logging}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Style="{StaticResource Muted}">
                        <Run Text="{DynamicResource UI_Settings_Format}"/>
                        <Run Text="{Binding LogFormat, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Content="{DynamicResource UI_Settings_ToggleLogFormat}" Margin="0,6,0,0"
                            Command="{Binding ToggleLogFormatCommand}"/>
                </StackPanel>
            </Border>

            <!-- Jobs -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource UI_Settings_Jobs}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource Muted}"
                               Text="{DynamicResource UI_Settings_MaxJobsDesc}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MaxJobsBox" Grid.Column="0"
                                 Text="{Binding MaxJobs, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="{DynamicResource UI_Btn_Save}" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ChangeMaxJobsCommand}"
                                CommandParameter="{Binding Text, ElementName=MaxJobsBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Business software -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource UI_Settings_BizMonitor}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource Muted}"
                               Text="{DynamicResource UI_Settings_BizMonitorDesc}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BusinessSoftwareBox" Grid.Column="0"
                                 Text="{Binding BusinessSoftwareName, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="{DynamicResource UI_Btn_Save}" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ChangeBusinessSoftwareNameCommand}"
                                CommandParameter="{Binding Text, ElementName=BusinessSoftwareBox}"/>
                    </Grid>

                    <TextBlock Text="{DynamicResource UI_Settings_BizCheckMode}"
                               Style="{StaticResource Muted}" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding BusinessSoftwareCheckMode}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource UI_Settings_ToggleBizCheckMode}"
                                Command="{Binding ToggleBusinessSoftwareCheckModeCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Encryption -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource UI_Settings_Encryption}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource Muted}"
                               Text="{DynamicResource UI_Settings_EncryptionDesc}"/>

                    <TextBlock Text="{DynamicResource UI_Settings_Mode}" Style="{StaticResource Muted}" Margin="0,12,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{Binding CryptoMode}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource UI_Settings_ToggleCryptoMode}"
                                Command="{Binding ToggleCryptoModeCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource UI_Settings_Extensions}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding EncryptedExtensions}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="4"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        <Button Content="x" Margin="6,0,0,0" Padding="4,0"
                                                Command="{Binding DataContext.RemoveExtensionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewExtensionBox" Grid.Column="0"
                                 Tag="e.g. .txt"/>
                        <Button Grid.Column="1" Content="{DynamicResource UI_Btn_Add}" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddExtensionCommand}"
                                CommandParameter="{Binding Text, ElementName=NewExtensionBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Paths -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource UI_Settings_PathsHeader}" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource UI_Path_Log}"   VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource UI_Path_State}" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding StatePath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource UI_Path_Config}" VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource UI_Path_Lang}"  VerticalAlignment="Center"/>
                        <TextBox   Grid.Column="1" Text="{Binding LangPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="{DynamicResource UI_Btn_SavePaths}" Style="{StaticResource PrimaryButton}" Click="SavePaths_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
