<UserControl x:Class="EasySave.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldHelp" TargetType="TextBlock" BasedOn="{StaticResource Subtitle}">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Stretch">

            <!-- Title -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource UI_Settings_Title}" Style="{StaticResource H1}"/>
                <TextBlock Text="{DynamicResource UI_Settings_Subtitle}" Style="{StaticResource Subtitle}"/>
            </StackPanel>

            <!-- APPARENCE -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_Appearance}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_Theme}"/>
                            <TextBlock Style="{StaticResource FieldHelp}" Text="{DynamicResource UI_Settings_ThemeDesc}"/>
                        </StackPanel>
                        <ComboBox x:Name="ThemeCombo" Grid.Column="1" VerticalAlignment="Center"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource UI_Theme_Light}" Tag="light"/>
                            <ComboBoxItem Content="{DynamicResource UI_Theme_Dark}"  Tag="dark"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- JOURNALISATION -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_Logging}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_LogFormatLabel}"/>
                            <TextBlock Style="{StaticResource FieldHelp}" Text="{DynamicResource UI_Settings_FormatDesc}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding LogFormat, Mode=TwoWay}">
                            <ComboBoxItem Content="JSON" Tag="json"/>
                            <ComboBoxItem Content="XML"  Tag="xml"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- LIMITES & PERFORMANCE -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_LimitsPerf}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_MaxJobsLabel}"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="{DynamicResource UI_Settings_MaxJobsDesc}"/>
                        </StackPanel>
                        <TextBox x:Name="MaxJobsBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding MaxJobs, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="{DynamicResource UI_Btn_Save}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Click="SaveMaxJobs_Click"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_MaxParallelJobsLabel}"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="{DynamicResource UI_Settings_MaxParallelJobsDesc}"/>
                        </StackPanel>
                        <TextBox x:Name="MaxParallelJobsBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding MaxParallelJobs, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="{DynamicResource UI_Btn_Save}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeMaxParallelJobsCommand}"
                                CommandParameter="{Binding Text, ElementName=MaxParallelJobsBox}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_MaxFilesLabel}"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="{DynamicResource UI_Settings_MaxFilesDesc}"/>
                        </StackPanel>
                        <TextBox x:Name="MaxParallelFilesBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding MaxParallelFilesPerJob, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="{DynamicResource UI_Btn_Save}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeMaxParallelFilesPerJobCommand}"
                                CommandParameter="{Binding Text, ElementName=MaxParallelFilesBox}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_LargeFileLabel}"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="{DynamicResource UI_Settings_LargeFileDesc}"/>
                        </StackPanel>
                        <TextBox x:Name="LargeFileThresholdBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding LargeFileThresholdKb, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="{DynamicResource UI_Btn_Save}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeLargeFileThresholdKbCommand}"
                                CommandParameter="{Binding Text, ElementName=LargeFileThresholdBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- LOGICIEL MÉTIER -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_BizMonitor}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="{DynamicResource UI_Settings_BizMonitorDesc}"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Settings_BizProcess}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox x:Name="BusinessSoftwareBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding BusinessSoftwareName, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="{DynamicResource UI_Btn_Save}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeBusinessSoftwareNameCommand}"
                                CommandParameter="{Binding Text, ElementName=BusinessSoftwareBox}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Settings_BizCheckModeLabel}" VerticalAlignment="Center" Margin="0"/>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="220"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding BusinessSoftwareCheckMode, Mode=TwoWay}">
                            <ComboBoxItem Content="{DynamicResource UI_Settings_BizMode_StartOnly}" Tag="StartOnly"/>
                            <ComboBoxItem Content="{DynamicResource UI_Settings_BizMode_Continuous}" Tag="Continuous"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CHIFFREMENT -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_Encryption}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="{DynamicResource UI_Settings_EncryptionDesc}"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Settings_Mode}" VerticalAlignment="Center" Margin="0"/>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="180"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CryptoMode, Mode=TwoWay}">
                            <ComboBoxItem Content="{DynamicResource UI_Settings_CryptoFast}"     Tag="Rapide"/>
                            <ComboBoxItem Content="{DynamicResource UI_Settings_CryptoStandard}" Tag="Standard"/>
                            <ComboBoxItem Content="{DynamicResource UI_Settings_CryptoPremium}"  Tag="Premium"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_ExtensionsTitle}"/>
                    <ItemsControl ItemsSource="{Binding EncryptedExtensions}" Margin="0,6,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Pill}" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="×" Margin="8,0,0,0" Padding="6,0"
                                                MinWidth="22"
                                                Command="{Binding DataContext.RemoveExtensionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Btn_Add}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox x:Name="NewExtensionBox" Grid.Column="1" VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Content="{DynamicResource UI_Btn_Add}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding AddExtensionCommand}"
                                CommandParameter="{Binding Text, ElementName=NewExtensionBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- EXTENSIONS PRIORITAIRES -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_Priority}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="{DynamicResource UI_Settings_PriorityDesc}" TextWrapping="Wrap"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Margin="0,0,0,6"
                               Text="{DynamicResource UI_Settings_Extensions}"/>
                    <ItemsControl ItemsSource="{Binding PriorityExtensions}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="4"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        <Button Content="x" Margin="6,0,0,0" Padding="4,0"
                                                Command="{Binding DataContext.RemovePriorityExtensionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Btn_Add}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox x:Name="NewPriorityExtensionBox" Grid.Column="1" VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Content="{DynamicResource UI_Btn_Add}"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding AddPriorityExtensionCommand}"
                                CommandParameter="{Binding Text, ElementName=NewPriorityExtensionBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CHEMINS -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{DynamicResource UI_Settings_PathsHeader}"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <!-- Bandeau affiché UNIQUEMENT en mode distant. -->
                    <Border x:Name="RemotePathsHint" Margin="0,0,0,12" Padding="10,6" Visibility="Collapsed"
                            Background="#FFF8E1" BorderBrush="#F0C36D" BorderThickness="1" CornerRadius="3">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#5B4A1E"
                                   Text="Ces chemins sont lus et écrits par le SERVEUR EasySave. Indique des dossiers qui existent sur la machine serveur, pas sur ce poste client. Les modifications prennent effet au redémarrage du serveur."/>
                    </Border>

                    <TextBlock x:Name="LocalPathsHelp" Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="{DynamicResource UI_Settings_PathsRestart}"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Path_Log}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button x:Name="BrowseLogButton" Grid.Column="2" Content="..." MinWidth="42" Margin="8,0,0,0"
                                ToolTip="Parcourir"
                                Tag="Log" Click="BrowsePath_Click"/>
                    </Grid>
                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Path_State}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding StatePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button x:Name="BrowseStateButton" Grid.Column="2" Content="..." MinWidth="42" Margin="8,0,0,0"
                                ToolTip="Parcourir"
                                Tag="State" Click="BrowsePath_Click"/>
                    </Grid>
                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Path_Config}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button x:Name="BrowseConfigButton" Grid.Column="2" Content="..." MinWidth="42" Margin="8,0,0,0"
                                ToolTip="Parcourir"
                                Tag="Config" Click="BrowsePath_Click"/>
                    </Grid>
                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{DynamicResource UI_Path_Lang}" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding LangPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button x:Name="BrowseLangButton" Grid.Column="2" Content="..." MinWidth="42" Margin="8,0,0,0"
                                ToolTip="Parcourir"
                                Tag="Lang" Click="BrowsePath_Click"/>
                    </Grid>

                    <Button Content="{DynamicResource UI_Btn_SavePaths}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Click="SavePaths_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
