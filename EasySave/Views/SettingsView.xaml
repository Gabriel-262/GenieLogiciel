<UserControl x:Class="EasySave.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldHelp" TargetType="TextBlock" BasedOn="{StaticResource Subtitle}">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Stretch">

            <!-- Title -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource UI_Settings_Title}" Style="{StaticResource H1}"/>
                <TextBlock Text="Préférences de l'application." Style="{StaticResource Subtitle}"/>
            </StackPanel>

            <!-- APPARENCE -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Apparence"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{DynamicResource UI_Settings_Theme}"/>
                            <TextBlock Style="{StaticResource FieldHelp}" Text="Thème clair ou sombre."/>
                        </StackPanel>
                        <ComboBox x:Name="ThemeCombo" Grid.Column="1" VerticalAlignment="Center"
                                  SelectedValuePath="Tag"
                                  SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource UI_Theme_Light}" Tag="light"/>
                            <ComboBoxItem Content="{DynamicResource UI_Theme_Dark}"  Tag="dark"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- JOURNALISATION -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Journalisation"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Format des logs"/>
                            <TextBlock Style="{StaticResource FieldHelp}" Text="Format de sortie des fichiers journaux."/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding LogFormat, Mode=TwoWay}">
                            <ComboBoxItem Content="JSON" Tag="json"/>
                            <ComboBoxItem Content="XML"  Tag="xml"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- LIMITES & PERFORMANCE -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Limites &amp; performance"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nombre max de travaux"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="{DynamicResource UI_Settings_MaxJobsDesc}"/>
                        </StackPanel>
                        <TextBox x:Name="MaxJobsBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding MaxJobs, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="Enregistrer"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Click="SaveMaxJobs_Click"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Travaux en parallèle"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="Nombre de travaux pouvant s'exécuter simultanément."/>
                        </StackPanel>
                        <TextBox x:Name="MaxParallelJobsBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding MaxParallelJobs, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="Enregistrer"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeMaxParallelJobsCommand}"
                                CommandParameter="{Binding Text, ElementName=MaxParallelJobsBox}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Fichiers // par travail"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="Fichiers traités en parallèle dans un même travail."/>
                        </StackPanel>
                        <TextBox x:Name="MaxParallelFilesBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding MaxParallelFilesPerJob, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="Enregistrer"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeMaxParallelFilesPerJobCommand}"
                                CommandParameter="{Binding Text, ElementName=MaxParallelFilesBox}"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Seuil « gros fichier » (Ko)"/>
                            <TextBlock Style="{StaticResource FieldHelp}"
                                       Text="Deux fichiers ≥ ce seuil ne sont jamais transférés ensemble. 0 = désactivé."/>
                        </StackPanel>
                        <TextBox x:Name="LargeFileThresholdBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding LargeFileThresholdKb, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="Enregistrer"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeLargeFileThresholdKbCommand}"
                                CommandParameter="{Binding Text, ElementName=LargeFileThresholdBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- LOGICIEL MÉTIER -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Surveillance logiciel métier"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="{DynamicResource UI_Settings_BizMonitorDesc}"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Processus" VerticalAlignment="Center" Margin="0"/>
                        <TextBox x:Name="BusinessSoftwareBox" Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding BusinessSoftwareName, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="Enregistrer"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding ChangeBusinessSoftwareNameCommand}"
                                CommandParameter="{Binding Text, ElementName=BusinessSoftwareBox}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Mode de vérification" VerticalAlignment="Center" Margin="0"/>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="220"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding BusinessSoftwareCheckMode, Mode=TwoWay}">
                            <ComboBoxItem Content="Au lancement uniquement" Tag="StartOnly"/>
                            <ComboBoxItem Content="Continue (avant chaque fichier)" Tag="Continuous"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CHIFFREMENT -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Chiffrement (CryptoSoft)"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="{DynamicResource UI_Settings_EncryptionDesc}"/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Mode" VerticalAlignment="Center" Margin="0"/>
                        <ComboBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="180"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CryptoMode, Mode=TwoWay}">
                            <ComboBoxItem Content="Rapide"   Tag="Rapide"/>
                            <ComboBoxItem Content="Standard" Tag="Standard"/>
                            <ComboBoxItem Content="Premium"  Tag="Premium"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Extensions chiffrées"/>
                    <ItemsControl ItemsSource="{Binding EncryptedExtensions}" Margin="0,6,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Pill}" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="×" Margin="8,0,0,0" Padding="6,0"
                                                MinWidth="22"
                                                Command="{Binding DataContext.RemoveExtensionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Ajouter" VerticalAlignment="Center" Margin="0"/>
                        <TextBox x:Name="NewExtensionBox" Grid.Column="1" VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Content="+ Ajouter"
                                Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                VerticalAlignment="Center"
                                Command="{Binding AddExtensionCommand}"
                                CommandParameter="{Binding Text, ElementName=NewExtensionBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- CHEMINS -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Chemins de stockage"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,16"/>

                    <TextBlock Style="{StaticResource FieldHelp}" Margin="0,0,0,12"
                               Text="Les modifications prennent effet au redémarrage."/>

                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Journaux" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="État" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding StatePath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Config" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="Langue" VerticalAlignment="Center" Margin="0"/>
                        <TextBox Grid.Column="1" Text="{Binding LangPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Button Content="Enregistrer les chemins"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Click="SavePaths_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
