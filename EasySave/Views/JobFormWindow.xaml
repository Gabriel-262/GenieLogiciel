<Window x:Class="EasySave.Views.JobFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EasySave.Views"
        Title="{DynamicResource UI_Window_JobForm_Title}"
        Width="560" Height="420"
        MinWidth="480" MinHeight="380"
        Style="{StaticResource AppWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Border Padding="20">
        <views:JobFormView DataContext="{Binding}"/>
    </Border>
</Window>
