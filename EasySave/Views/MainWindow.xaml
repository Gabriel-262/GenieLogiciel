<Window x:Class="EasySave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EasySave.Views"
        Title="Easy Save"
        Icon="/Icone.ico"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="560"
        Style="{StaticResource AppWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <!-- Brand -->
                <Border DockPanel.Dock="Top" Padding="20,22,20,18">
                    <TextBlock Text="Easy Save"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </Border>

                <!-- Language footer (dropdown) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="20,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource UI_Sidebar_LanguageLabel}" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="LanguageCombo"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding Settings.Language, Mode=TwoWay}">
                            <ComboBoxItem Content="English"  Tag="en"/>
                            <ComboBoxItem Content="Français" Tag="fr"/>
                            <ComboBoxItem Content="中文"     Tag="zh"/>
                            <ComboBoxItem Content="עברית"   Tag="he"/>
                            <ComboBoxItem Content="Kreyòl"  Tag="ht"/>
                            <ComboBoxItem Content="Ch'ti"  Tag="ch"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Nav -->
                <StackPanel Margin="0,8,0,0">
                    <Button Style="{StaticResource NavButton}" Click="NavJobs_Click">
                        <TextBlock Text="{DynamicResource UI_Sidebar_Jobs}"/>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavLogs_Click">
                        <TextBlock Text="{DynamicResource UI_Sidebar_Logs}"/>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NavSettings_Click">
                        <TextBlock Text="{DynamicResource UI_Sidebar_Settings}"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl x:Name="ContentHost" Grid.Column="1" Margin="28,24,28,24"/>
    </Grid>
</Window>
