<Window x:Class="EasySave.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EasySave.Views"
        Title="{DynamicResource UI_Window_Main_Title}"
        Icon="/Icone.ico"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="520"
        Style="{StaticResource AppWindow}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="16">
                <TextBlock Text="EasySave" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="v2.0" Style="{StaticResource Muted}" Margin="0,0,0,24"/>

                <Button Content="{DynamicResource UI_Sidebar_Jobs}"      Margin="0,0,0,6" Click="NavJobs_Click"      HorizontalContentAlignment="Left"/>

                <Grid Margin="0,0,0,6">
                    <Button Content="{DynamicResource UI_Sidebar_Execution}" Click="NavExecution_Click" HorizontalContentAlignment="Left"/>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            Background="#DC2626"
                            CornerRadius="10"
                            MinWidth="20" Height="20"
                            Padding="6,0"
                            Visibility="{Binding IsExecutionBadgeVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding UnseenExecutionCount}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <Button Content="{DynamicResource UI_Sidebar_Settings}"  Margin="0,0,0,6" Click="NavSettings_Click"  HorizontalContentAlignment="Left"/>

                <TextBlock Text="{Binding Settings.LanguageDisplayName}"
                           Style="{StaticResource Muted}" Margin="0,24,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ContentControl x:Name="ContentHost" Grid.Column="1" Margin="24"/>
    </Grid>
</Window>
