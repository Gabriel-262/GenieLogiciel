<UserControl x:Class="EasySave.Views.JobExecutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource UI_Exec_Title}" Style="{StaticResource H1}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Une carte par job en cours d'exécution -->
                <ItemsControl ItemsSource="{Binding Jobs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Bandeau pause par job -->
                                    <Border Background="#E67E22"
                                            CornerRadius="6"
                                            Padding="14,10"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="⏸  Sauvegarde en pause"
                                                           Foreground="White" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="Fichier verrouillé ou logiciel métier détecté. Cliquez sur Reprendre quand c'est libre."
                                                           Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="▶ Reprendre"
                                                    Command="{Binding ResumeCommand}"
                                                    Padding="14,6"
                                                    Margin="12,0,0,0"
                                                    FontWeight="Bold"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="{DynamicResource UI_Exec_CurrentJob}" Style="{StaticResource Muted}"/>
                                    <TextBlock Text="{Binding JobName, FallbackValue='—'}"
                                               FontSize="16" FontWeight="SemiBold" Margin="0,4,0,12"/>

                                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Margin="0,0,0,8"/>
                                    <TextBlock Margin="0,0,0,12">
                                        <Run Text="{Binding ProcessedFiles}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding TotalFiles}"/>
                                        <Run Text="{DynamicResource UI_Exec_Files}"/>
                                        <Run Text="{Binding ProgressPercent, StringFormat={}{0:0.0}%}"/>
                                    </TextBlock>

                                    <TextBlock Text="{DynamicResource UI_Col_Source}" Style="{StaticResource Muted}"/>
                                    <TextBlock Text="{Binding CurrentSourceFile, FallbackValue=''}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,8"/>

                                    <TextBlock Text="{DynamicResource UI_Exec_Destination}" Style="{StaticResource Muted}"/>
                                    <TextBlock Text="{Binding CurrentDestinationFile, FallbackValue=''}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
