<UserControl x:Class="EasySave.Views.JobListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="RequiresSelection" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Grid, Path=SelectedItem}" Value="{x:Null}">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RequiresSelectionDanger" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Grid, Path=SelectedItem}" Value="{x:Null}">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource UI_JobList_Title}" Style="{StaticResource H1}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
            <Button Content="{DynamicResource UI_Btn_Add}"         Style="{StaticResource PrimaryButton}"        Click="Add_Click"/>
            <Button Content="{DynamicResource UI_Btn_Edit}"        Style="{StaticResource RequiresSelection}"    Click="Edit_Click"/>
            <Button Content="{DynamicResource UI_Btn_Delete}"      Style="{StaticResource RequiresSelectionDanger}" Click="Delete_Click"/>
            <Button Content="{DynamicResource UI_Btn_Execute}"     Click="Execute_Click"
                    IsEnabled="{Binding JobList.HasAnyChecked}"/>
            <Button Content="{DynamicResource UI_Btn_ExecuteAll}"  Click="ExecuteAll_Click"/>
            <Button Content="{DynamicResource UI_Btn_SelectAll}"   Click="SelectAll_Click"/>
            <Button Content="{DynamicResource UI_Btn_DeselectAll}" Click="DeselectAll_Click"/>
            <Button Content="{DynamicResource UI_Btn_Refresh}"     Click="Refresh_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource UI_Exec_InProgress}"
                   Style="{StaticResource Muted}"
                   Margin="0,0,0,12"
                   Visibility="{Binding IsExecutionBadgeVisible, Converter={StaticResource BoolToVis}}"/>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="Grid" ItemsSource="{Binding JobList.Jobs}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource UI_Col_Id}"     Binding="{Binding Id}"         Width="60"/>
                    <DataGridTextColumn Header="{DynamicResource UI_Col_Name}"   Binding="{Binding Name}"       Width="*"/>
                    <DataGridTextColumn Header="{DynamicResource UI_Col_Type}"   Binding="{Binding Type}"       Width="120"/>
                    <DataGridTextColumn Header="{DynamicResource UI_Col_Source}" Binding="{Binding SourcePath}" Width="2*"/>
                    <DataGridTextColumn Header="{DynamicResource UI_Col_Target}" Binding="{Binding TargetPath}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
